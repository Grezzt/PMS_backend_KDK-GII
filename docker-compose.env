# =============================================================================
# PMS Backend — Environment Variables
# Salin file ini ke .env untuk development lokal
# =============================================================================

# Moleculer
NAMESPACE=
LOGGER=true
LOGLEVEL=info
SERVICEDIR=services
TRANSPORTER=nats://nats:4222
CACHER=redis://redis:6379

# PostgreSQL (Prisma)
POSTGRES_USER=pms_user
POSTGRES_PASSWORD=pms_password
POSTGRES_DB=pms_db
DATABASE_URL=postgresql://pms_user:pms_password@postgres:5432/pms_db

# MongoDB (user_tokens & audit_logs)
MONGO_USER=pms_mongo
MONGO_PASSWORD=pms_mongo_pass
MONGO_URI=mongodb://pms_mongo:pms_mongo_pass@mongo:27017/pms_nosql?authSource=admin

# Redis
REDIS_PASSWORD=redis_pass

# JWT
JWT_SECRET=ganti-dengan-secret-panjang-min-32-karakter-di-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Channel & Workflows
CHANNEL_URL=nats://nats:4222
WORKFLOWS_URL=redis://redis:6379

# App
PORT=3000
NODE_ENV=development
