{
  "name": "pms-backend",
  "version": "1.0.0",
  "description": "PMS Backend — Moleculer Microservices with PostgreSQL & MongoDB",
  "scripts": {
    "dev": "moleculer-runner --repl --hot services/**/*.service.js",
    "start": "moleculer-runner",
    "cli": "moleculer connect NATS",
    "ci": "jest --watch",
    "test": "jest --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset --force",
    "migrate:status": "prisma migrate status",
    "studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:format": "prisma format",
    "db:setup": "npm run generate && npm run migrate && npm run db:seed",
    "db:up": "docker compose up postgres mongo -d",
    "db:down": "docker compose stop postgres mongo",
    "db:logs": "docker compose logs -f postgres mongo",
    "db:reset": "docker compose down -v && npm run db:up",
    "mongo:shell": "docker exec -it pms_mongo mongosh -u pms_mongo -p pms_mongo_pass --authenticationDatabase admin",
    "pg:shell": "docker exec -it pms_postgres psql -U pms_user -d pms_db",
    "dc:up": "docker compose up --build -d",
    "dc:logs": "docker compose logs -f",
    "dc:down": "docker compose down"
  },
  "keywords": [
    "microservices",
    "moleculer"
  ],
  "author": "",
  "devDependencies": {
    "@prisma/config": "^7.7.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "moleculer-repl": "^0.8.0",
    "mongo-express": "^1.1.0-rc-4",
    "prettier": "^3.5.3",
    "prisma": "^7.7.0",
    "supertest": "^7.1.1",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@moleculer/channels": "^0.3.1",
    "@moleculer/database": "^0.4.0",
    "@moleculer/workflows": "^0.2.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@seald-io/nedb": "^4.1.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "moleculer": "^0.15.0",
    "moleculer-web": "^0.11.0",
    "mongodb": "^7.1.1",
    "nats": "^2.29.3",
    "pg": "^8.20.0"
  },
  "engines": {
    "node": ">= 22.x.x"
  },
  "jest": {
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "rootDir": "./",
    "roots": [
      "./test"
    ],
    "testMatch": [
      "**/test/**/*.spec.js"
    ]
  }
}
