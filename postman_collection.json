  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "1. User Registration",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"password\": \"secret123\",\n    \"email\": \"john.doe@example.com\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register pengguna baru. Mengembalikan HTTP 201 Created dengan data user."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {"method": "POST", "body": {"mode": "raw", "raw": "{\"name\":\"Fresh User\",\"email\":\"freshpms2026@example.com\",\"password\":\"test1234\"}"}},
              "status": "Created", "code": 201,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Created\",\n  \"code\": 201,\n  \"type\": \"CREATED\",\n  \"data\": {\n    \"id\": \"26650014-1329-4571-8a3b-02b2aea9e541\",\n    \"name\": \"Fresh User\",\n    \"email\": \"freshpms2026@example.com\",\n    \"role\": \"MEMBER\",\n    \"createdAt\": \"2026-05-13T03:35:10.875Z\",\n    \"updatedAt\": \"2026-05-13T03:35:10.875Z\"\n  }\n}"
            },
            {
              "name": "409 Conflict - Email Already Registered",
              "originalRequest": {"method": "POST", "body": {"mode": "raw", "raw": "{\"name\":\"Fresh User\",\"email\":\"freshpms2026@example.com\",\"password\":\"test1234\"}"}},
              "status": "Conflict", "code": 409,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Email already registered\",\n  \"code\": 409,\n  \"type\": \"ERR_EMAIL_EXISTS\"\n}"
            },
            {
              "name": "422 Unprocessable - Validation Error",
              "originalRequest": {"method": "POST", "body": {"mode": "raw", "raw": "{\"name\":\"A\",\"email\":\"not-email\"}"}},
              "status": "Unprocessable Entity", "code": 422,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Parameters validation error!\",\n  \"code\": 422,\n  \"type\": \"VALIDATION_ERROR\",\n  \"data\": [\n    {\"type\": \"stringMin\", \"message\": \"The 'name' field length must be greater than or equal to 2 characters long.\", \"field\": \"name\", \"expected\": 2, \"actual\": 1},\n    {\"type\": \"email\", \"message\": \"The 'email' field must be a valid e-mail.\", \"field\": \"email\", \"actual\": \"not-email\"},\n    {\"type\": \"required\", \"message\": \"The 'password' field is required.\", \"field\": \"password\"}\n  ]\n}"
            }
          ]
        },
        {
          "name": "2. User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.accessToken) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.accessToken);",
                  "    pm.environment.set(\"refresh_token\", jsonData.refreshToken);",
                  "    console.log(\"Tokens automatically saved to environment variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"secret123\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login dan dapatkan JWT Access Token & Refresh Token. Script otomatis menyimpan token ke environment variable."
          },
          "response": [
            {
              "name": "200 OK - Login Success",
              "originalRequest": {"method": "POST", "body": {"mode": "raw", "raw": "{\"email\":\"testpms2026@example.com\",\"password\":\"test1234\"}"}},
              "status": "OK", "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjI1NWNjMTc2...\",\n  \"refreshToken\": \"97e1bd29589d73a7d407d129e06d28c9c5532d5076cef6aa6d2ead91...\",\n  \"expiresIn\": \"2h\"\n}"
            },
            {
              "name": "401 Unauthorized - Invalid Credentials",
              "originalRequest": {"method": "POST", "body": {"mode": "raw", "raw": "{\"email\":\"testpms2026@example.com\",\"password\":\"wrongpassword\"}"}},
              "status": "Unauthorized", "code": 401,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Invalid email or password\",\n  \"code\": 401,\n  \"type\": \"ERR_INVALID_CREDS\"\n}"
            }
          ]
        },
        {
          "name": "3. Get My Profile (Protected)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{"key": "token", "value": "{{jwt_token}}", "type": "string"}]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Ambil profil user dari token JWT. Token diambil otomatis dari env variable jwt_token."
          },
          "response": [
            {
              "name": "200 OK - Profile",
              "status": "OK", "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"OK\",\n  \"code\": 200,\n  \"type\": \"SUCCESS\",\n  \"data\": {\n    \"id\": \"255cc176-e304-4733-baa0-386a14b64aa8\",\n    \"name\": \"Test User Updated\",\n    \"email\": \"testpms2026@example.com\",\n    \"role\": \"MEMBER\",\n    \"createdAt\": \"2026-05-13T03:33:35.848Z\",\n    \"updatedAt\": \"2026-05-13T03:35:11.868Z\"\n  }\n}"
            },
            {
              "name": "401 Unauthorized - Invalid Token",
              "status": "Unauthorized", "code": 401,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Unauthorized\",\n  \"code\": 401,\n  \"type\": \"INVALID_TOKEN\"\n}"
            }
          ]
        },
        {
          "name": "4. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.accessToken) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.accessToken);",
                  "    console.log(\"New Access Token automatically saved!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Gunakan refresh_token dari environment variable untuk mendapatkan access token baru."
          },
          "response": [
            {
              "name": "200 OK - New Tokens",
              "status": "OK", "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6...\",\n  \"refreshToken\": \"newrefreshtoken...\",\n  \"expiresIn\": \"2h\"\n}"
            },
            {
              "name": "401 Unauthorized - Invalid/Expired Refresh Token",
              "status": "Unauthorized", "code": 401,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Unauthorized\",\n  \"code\": 401,\n  \"type\": \"ERR_UNAUTHORIZED\"\n}"
            }
          ]
        },
        {
          "name": "5. Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Revoke refresh token. Token yang sudah di-logout tidak bisa digunakan kembali."
          },
          "response": [
            {
              "name": "204 No Content - Logout Success",
              "status": "No Content", "code": 204,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": ""
            },
            {
              "name": "401 Unauthorized - Token Already Revoked",
              "status": "Unauthorized", "code": 401,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Unauthorized\",\n  \"code\": 401,\n  \"type\": \"ERR_UNAUTHORIZED\"\n}"
            }
          ]
        }
      ],
      "description": "Grup endpoint terkait autentikasi (Registrasi, Login, Profil, Refresh, Logout)."
    },
